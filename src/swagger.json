{
  "openapi": "3.0.0",
  "info": {
    "title": "Landing Manager API",
    "version": "1.0.0",
    "description": "API Documentation for the Landing Manager Backend"
  },
  "servers": [
    {
      "url": "https://egypt-solution-back-end.vercel.app",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:5000",
      "description": "Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken"
      }
    },
    "schemas": {
      "AnalyticsInput": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string",
            "enum": [
              "7d",
              "30d",
              "90d",
              "12m"
            ]
          }
        }
      },
      "UserRegisterInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "newuser@example.com"
          },
          "password": {
            "type": "string",
            "example": "P@ssword123!"
          }
        }
      },
      "UserLoginInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ClientInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "link": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CompanyInfoInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "socialLinks": {
            "type": "object"
          },
          "lang": {
            "type": "string",
            "enum": [
              "en",
              "ar"
            ]
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "NEW",
              "READ",
              "REPLIED"
            ]
          }
        }
      },
      "HeroInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "ctaText": {
            "type": "string"
          },
          "ctaLink": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "ProjectCreateInput": {
        "type": "object",
        "required": [
          "title",
          "description",
          "link"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Landing Manager Platform"
          },
          "description": {
            "type": "string",
            "example": "A fully scalable backend architecture solution."
          },
          "link": {
            "type": "string",
            "example": "https://github.com"
          },
          "active": {
            "type": "boolean",
            "default": false
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SlideShowInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "TeamMemberInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "TestimonialInput": {
        "type": "object",
        "properties": {
          "clientName": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "active": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": [],
      "cookieAuth": []
    }
  ],
  "paths": {
    "/api/analytics/overview": {
      "get": {
        "tags": [
          "Analytics"
        ],
        "summary": "Retrieve general overview analytics",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "period",
            "schema": {
              "type": "string",
              "enum": [
                "7d",
                "30d",
                "90d",
                "12m"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics data returned"
          },
          "401": {
            "description": "Unauthorized (Requires ADMIN)"
          }
        }
      }
    },
    "/api/analytics/top-pages": {
      "get": {
        "tags": [
          "Analytics"
        ],
        "summary": "Retrieve most visited pages stats",
