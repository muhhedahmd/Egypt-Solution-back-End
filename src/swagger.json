        },
        "responses": {
          "200": {
            "description": "User logged in successfully"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "429": {
            "description": "Too many login attempts"
          }
        }
      }
    },
    "/api/auth/send-otp": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Send OTP for verification",
