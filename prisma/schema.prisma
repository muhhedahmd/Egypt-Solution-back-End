// ============================================================================
// SOFTWARE COMPANY WEBSITE SCHEMA
// Features: Portfolio, Services, Team, Blog, Contact, Analytics
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ImageType {
  PROFILE
  SERVICE
  PROJECT
  SLIDESHOW
  CLIENT
  BLOG
  TEAM
  HERO
  TESTIMONIAL
  COMPANY_LOGO
}

enum SlideshowType {
  SERVICES
  PROJECTS
  TESTIMONIALS
  TEAM
  CLIENTS
  HERO
  CUSTOM
}

enum CompositionType {
  SINGLE
  GRID
  CAROUSEL
  STACKED
  FADE
  CUSTOM

  ZOOM
  PARALLAX
  COVERFLOW
  KEN_BURNS
  FLIP
  CUBE
  AUTO_GRID
  STORY
  FILMSTRIP
  LIGHTBOX
  MARQUEE
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum ContactStatus {
  NEW
  READ
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================
model User {
  
  id                      String   @id @default(cuid())
  name                    String
  email                   String   @unique
  password                String
  gender                  Gender   @default(MALE)
  role                    UserRole @default(ADMIN)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  is2FA                   Boolean  @default(false)
  isVerifiedForEachDevice Boolean  @default(false)
  emailConfirmed          Boolean  @default(false)
  googleId                String?

  profile  Profile?
  sessions Session[]
  blogs    Blog[]

  @@map("users")
}

model Session {
  id                    String   @id @default(cuid())
  userId                String
  token                 String   @unique
  userAgent             String?
  ipAddress             String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime
  isActive              Boolean  @default(true)
  deviceVerification    Boolean  @default(false)
  twoFactorVerification Boolean  @default(false)
  expiresAt             DateTime
  createdAt             DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  phone             String?
  dateOfBirth       DateTime?
  bio               String?
  avatarId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isProfileComplete Boolean   @default(false)
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar            Image?    @relation("ProfileAvatar", fields: [avatarId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================================================
// COMPANY INFO
// ============================================================================

// EnumLang 

enum EnumLang {
  EN
  AR
}

model CompanyInfo {

  id          String  @id @default(cuid())
  name        String
  tagline     String?
  description String?
  email       String
  phone       String?
  address     String?
  city        String?
  country     String?
  postalCode  String?
  fotterText  String?

  // Social Media
  facebook  String?
  twitter   String?
  linkedin  String?
  instagram String?
  github    String?
  youtube   String?
  website   String?

  lang EnumLang @default(EN)

  companyTranslation CompanyTranslation[]
  // SEO
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logo      Image?   @relation("CompanyInfoImage", fields: [logoId], references: [id])
  logoId    String?

  @@map("company_info")
}

model CompanyTranslation {
  id   String   @id @default(cuid())
  lang EnumLang

  name        String
  tagline     String?
  description String?
  footerText  String?

  // SEO (translated)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  // Relation
  company   CompanyInfo @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, lang])
  @@map("company_translation")
}

enum TextAlign {
  LEFT
  CENTER
  RIGHT
}

enum ButtonVariant {
  PRIMARY
  SECONDARY
  GHOST
  LINK
}

// ============================================================================
// HERO SECTION
// ============================================================================

model Hero {
  id          String  @id @default(cuid())
  name        String  @default("Main Hero")
  title       String
  subtitle    String?
  description String? @db.Text

  // Background
  backgroundImageId String?
  backgroundImage   Image?  @relation("HeroBackgroundImage", fields: [backgroundImageId], references: [id])
  backgroundColor   String? @default("#f5f5f5")

  backgroundVideo   String? // Video URL
  overlayColor      String? // For image/video overlay
  overlayOpacity    Float?  @default(0.5)

  // Primary CTA
  ctaText    String?        @default("Get Started")
  ctaUrl     String?        @default("/contact")
  ctaVariant ButtonVariant? @default(PRIMARY)

  // Secondary CTA
  secondaryCtaText    String?
  secondaryCtaUrl     String?
  secondaryCtaVariant ButtonVariant? @default(GHOST)

  // Layout / style
  alignment TextAlign?  @default(CENTER)
  variant   HeroVariant @default(CENTERED)
  minHeight Int?        @default(600) // pixels

  // Content styling
  titleSize        String? @default("4xl") // Tailwind size class
  titleColor       String? @default("#000000")
  subtitleColor    String? @default("#666666")
  descriptionColor String? @default("#888888")

  // Additional features
  showScrollIndicator Boolean @default(false)
  customCSS           String? @db.Text
  styleOverrides      Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  HeroTranslation HeroTranslation[] @relation("hero_translation_rel")

  @@map("heroes")
}

model HeroTranslation {
  id   String   @id @default(cuid())
  lang EnumLang

  name             String  @default("Main Hero")
  title            String
  subtitle         String?
  description      String? @db.Text
  ctaText          String? @default("Get Started")
  secondaryCtaText String?

  // Relation
  hero   Hero   @relation("hero_translation_rel", fields: [heroId], references: [id], onDelete: Cascade)
  heroId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([heroId, lang])
  @@map("hero_translation")
}

enum HeroVariant {
  CENTERED
  SPLIT
  IMAGE_BACKGROUND
  MINIMAL
  FULL_SCREEN
}

// ============================================================================
// HEADER
// ============================================================================

model Header {
  id                   String              @id @default(cuid())
  logo                 String?
  siteName             String
  tagline              String?
  showSearch           Boolean             @default(false)
  showLanguageSelector Boolean             @default(false)
  isSticky             Boolean             @default(false)
  backgroundColor      String?
  textColor            String?
  height               Int?                @default(80)
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  navItems             HeaderNavItem[]
  HeaderTranslation    HeaderTranslation[] @relation("Header_translation_rel")

  @@map("headers")
}

model HeaderTranslation {
  id       String   @id @default(cuid())
  lang     EnumLang
  siteName String
  tagline  String?

  // Relation
  header   Header @relation("Header_translation_rel", fields: [headerId], references: [id], onDelete: Cascade)
  headerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([headerId, lang])
  @@map("header_translation")
}

model HeaderNavItem {

  id           String  @id @default(cuid())
  headerId     String
  label        String
  url          String
  order        Int     @default(0)
  isExternal   Boolean @default(false)
  openInNewTab Boolean @default(false)
  parentId     String?
  isActive     Boolean @default(true)
  icon         String?

  header   Header          @relation(fields: [headerId], references: [id], onDelete: Cascade)
  parent   HeaderNavItem?  @relation("NavItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children HeaderNavItem[] @relation("NavItemChildren")
  HeaderNavItemTranslation HeaderNavItemTranslation[] @relation("header_nav_item_translation_rel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([headerId, order])
  @@index([parentId])
  @@map("header_nav_items")
}

// ============================================================================
// FOOTER
// ============================================================================

model Footer {

  id              String  @id @default(cuid())
  copyrightText   String
  showSocialLinks Boolean @default(true)
  showNewsletter  Boolean @default(false)
  backgroundColor String?
  textColor       String?
  isActive        Boolean @default(true)

  columns   FooterColumn[]
  FooterTranslation FooterTranslation[] @relation("footer_translation_rel")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("footers")
}

model FooterColumn {

  id       String  @id @default(cuid())
  footerId String
  title    String
  order    Int     @default(0)
  isActive Boolean @default(true)
  FooterColumnTranslation FooterColumnTranslation[] @relation("footer_column_translation_rel")


  footer    Footer       @relation(fields: [footerId], references: [id], onDelete: Cascade)
  links     FooterLink[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([footerId, order])
  @@map("footer_columns")
}

model FooterLink {

  id           String  @id @default(cuid())
  columnId     String
  label        String
  url          String
  order        Int     @default(0)
  isExternal   Boolean @default(false)
  openInNewTab Boolean @default(false)
  isActive     Boolean @default(true)
  icon         String?

  FooterLinkTranslation FooterLinkTranslation[]  @relation("footer_link_translation")

  column    FooterColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([columnId, order])
  @@map("footer_links")
}

// ============================================================================
// SERVICES
// ============================================================================

model Service {
  id              String  @id @default(cuid())
  name            String?
  slug            String  @unique
  description     String?
  richDescription String? @db.Text
  icon            String? // Icon name or URL
  imageId         String?
  price           String? // e.g., "Starting from $5000"
  isActive        Boolean @default(true)
  isFeatured      Boolean @default(false)
  order           Int     @default(0)

  image      Image?             @relation("ServiceImage", fields: [imageId], references: [id])
  slideShows ServiceSlideShow[]
  projects   Project[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]
  serviceTranslation serviceTranslation[] @relation("service_translation_rel")

  @@index([slug])
  @@index([isActive])
  @@map("services")
}

model serviceTranslation {
  id       String   @id @default(cuid())
  lang     EnumLang
  name            String
  description     String?
  richDescription String? @db.Text


  // Relation
  service  Service @relation("service_translation_rel", fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, lang])
  @@map("service_translation")
}

// ============================================================================
// PROJECTS/PORTFOLIO
// ============================================================================

model Project {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String?
  richDescription String?       @db.Text
  clientName      String?
  clientCompany   String?
  projectUrl      String?
  githubUrl       String?
  status          ProjectStatus @default(COMPLETED)
  startDate       DateTime?
  endDate         DateTime?
  imageId         String?
  isFeatured      Boolean       @default(false)
  order           Int           @default(0)

  image        Image?              @relation("ProjectImage", fields: [imageId], references: [id])
  services     Service[]
  technologies ProjectTechnology[]
  slideShows   ProjectSlideShow[]
  ProjectTranslation ProjectTranslation[] @relation("project_translation_rel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isFeatured])
  @@map("projects")
}


model Technology {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  icon     String? // Icon name or URL
  category String? // e.g., "Frontend", "Backend", "Database"

  projects  ProjectTechnology[]
  TechnologyTranslation  TechnologyTranslation[] @relation("technology_translation_rel")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@map("technologies")
}

model ProjectTechnology {
  projectId    String
  technologyId String

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([projectId, technologyId])
}

// ============================================================================
// TEAM
// ============================================================================

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  position String
  bio      String? @db.Text
  email    String?
  phone    String?
  imageId  String?

  // Social
  linkedin String?
  github   String?
  twitter  String?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  order      Int     @default(0)

  image      Image?          @relation("TeamImage", fields: [imageId], references: [id])
  slideShows TeamSlideShow[]
  TeamMemberTranslation TeamMemberTranslation[] @relation("team_member_translation_rel")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("team_members")
}

// ============================================================================
// CLIENTS
// ============================================================================

model Client {
  id              String  @id @default(cuid())
  name            String
  slug            String  @unique
  description     String?
  richDescription String? @db.Text
  website         String?
  industry        String?
  imageId         String?
  logoId          String?
  isActive        Boolean @default(true)
  isFeatured      Boolean @default(false)
  order           Int     @default(0)

  image      Image?            @relation("ClientImage", fields: [imageId], references: [id])
  logo       Image?            @relation("ClientLogo", fields: [logoId], references: [id])
  slideShows ClientSlideShow[]
  ClientTranslation ClientTranslation[] @relation("client_translation_rel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("clients")
}

// ============================================================================
// TESTIMONIALS
// ============================================================================

model Testimonial {
  id             String  @id @default(cuid())
  clientName     String
  clientPosition String?
  clientCompany  String?
  content        String  @db.Text
  rating         Int     @default(5)
  avatarId       String?
  isActive       Boolean @default(true)
  isFeatured     Boolean @default(false)
  order          Int     @default(0)

  avatar     Image?                 @relation("TestimonialAvatar", fields: [avatarId], references: [id])
  slideShows TestimonialSlideShow[]
  TestimonialTranslation TestimonialTranslation[] @relation("testimonial_translation_rel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

// ============================================================================
// BLOG
// ============================================================================

model BlogViewer {
  id     String @id @default(cuid())
  blogId String

  sessionId String

  ipHash    String? // Hashed IP as backup identifier
  userAgent String? @db.Text

  // Optional analytics metadata
  referrer String?
  country  String? // From IP geolocation (optional)
  device   String? // "mobile" | "tablet" | "desktop"

  viewedAt DateTime @default(now())
  duration Int? // Reading time in seconds

  blog Blog @relation("BlogViewers", fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, sessionId])
  @@index([blogId])
  @@index([sessionId])
  @@index([viewedAt])
  @@map("blog_viewers")
}

// Update Blog model to include the relation
model Blog {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String?
  content         String     @db.Text
  imageId         String?
  authorId        String
  status          BlogStatus @default(DRAFT)
  publishedAt     DateTime?
  isFeatured      Boolean    @default(false)
  readingTime     Int?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  image      Image?         @relation("BlogImage", fields: [imageId], references: [id])
  author     User           @relation(fields: [authorId], references: [id])
  categories BlogCategory[]
  viewers    BlogViewer[]   @relation("BlogViewers") 
  BlogTranslation BlogTranslation[] @relation("blog_translation_rel")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("blogs")
}

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
  CategoryTranslation CategoryTranslation[] @relation("category_translation_rel")

  blogs     BlogCategory[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("categories")
}

// relation 
model BlogCategory {

  blogId     String
  categoryId String

  blog     Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([blogId, categoryId])
}

// ============================================================================
// SLIDESHOW SYSTEM
// ============================================================================

model SlideShow {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String?
  type        SlideshowType
  composition CompositionType
  background  String? // CSS color or gradient
  isActive    Boolean         @default(true)
  autoPlay    Boolean         @default(false)
  interval    Int             @default(5000) // milliseconds
  order       Int             @default(0)

  services     ServiceSlideShow[]
  projects     ProjectSlideShow[]
  clients      ClientSlideShow[]
  testimonials TestimonialSlideShow[]
  team         TeamSlideShow[]
  SlideShowTranslation SlideShowTranslation[] @relation("slideshow_translation_rel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([type])
  @@map("slideshows")
}

model ServiceSlideShow {
  id          String  @id @default(cuid())
  serviceId   String
  slideShowId String
  order       Int     @default(0)
  isVisible   Boolean @default(true)
  customTitle String?
  customDesc  String?

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  slideShow SlideShow @relation(fields: [slideShowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, slideShowId])
  @@index([slideShowId, order])
}

model ProjectSlideShow {
  id          String  @id @default(cuid())
  projectId   String
  slideShowId String
  order       Int     @default(0)
  isVisible   Boolean @default(true)

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slideShow SlideShow @relation(fields: [slideShowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, slideShowId])
  @@index([slideShowId, order])
}

model ClientSlideShow {
  id          String  @id @default(cuid())
  clientId    String
  slideShowId String
  order       Int     @default(0)
  isVisible   Boolean @default(true)

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  slideShow SlideShow @relation(fields: [slideShowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, slideShowId])
  @@index([slideShowId, order])
}

model TestimonialSlideShow {
  id            String  @id @default(cuid())
  testimonialId String
  slideShowId   String
  order         Int     @default(0)
  isVisible     Boolean @default(true)

  testimonial Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
  slideShow   SlideShow   @relation(fields: [slideShowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([testimonialId, slideShowId])
  @@index([slideShowId, order])
}

model TeamSlideShow {
  id          String  @id @default(cuid())
  teamId      String
  slideShowId String
  order       Int     @default(0)
  isVisible   Boolean @default(true)

  team      TeamMember @relation(fields: [teamId], references: [id], onDelete: Cascade)
  slideShow SlideShow  @relation(fields: [slideShowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, slideShowId])
  @@index([slideShowId, order])
}

// ============================================================================
// CONTACT & INQUIRIES
// ============================================================================

enum ContactPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ContactCategory {
  GENERAL_INQUIRY
  SUPPORT
  SALES
  PARTNERSHIP
  FEEDBACK
  COMPLAINT
  SERVICE_INQUIRY
  OTHER
}

model Contact {
  id String @id @default(cuid())

  name    String
  email   String
  phone   String?
  company String?

  category ContactCategory @default(GENERAL_INQUIRY)
  subject  String
  message  String          @db.Text

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  budget    String?
  timeline  String?

  status   ContactStatus   @default(NEW)
  priority ContactPriority @default(MEDIUM)

  ipAddress String?
  userAgent String?
  source    String?
  referrer  String?

  respondedAt DateTime?
  respondedBy String?
  notes       String?   @db.Text
  response    String?   @db.Text
  resolved    Boolean   @default(false)

  // Engagement
  readAt    DateTime?
  viewCount Int       @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([serviceId])
  @@index([email])
  @@index([createdAt])
  @@index([resolved])
  @@map("contacts")
}

// ============================================================================
// MEDIA MANAGEMENT
// ============================================================================

model Image {
  id        String    @id @default(cuid())
  filename  String
  url       String
  alt       String?
  size      Int? // bytes
  width     Int?
  height    Int?
  blurHash  String?
  fileHash  String
  key       String
  imageType ImageType
  type      String
  customId  String?

  profileAvatars Profile[]     @relation("ProfileAvatar")
  services       Service[]     @relation("ServiceImage")
  projects       Project[]     @relation("ProjectImage")
  clients        Client[]      @relation("ClientImage")
  clientLogos    Client[]      @relation("ClientLogo")
  testimonials   Testimonial[] @relation("TestimonialAvatar")
  teamMembers    TeamMember[]  @relation("TeamImage")
  blogs          Blog[]        @relation("BlogImage")
  companyInfos   CompanyInfo[] @relation("CompanyInfoImage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  heroes    Hero[]   @relation("HeroBackgroundImage")

  @@index([type])
  @@map("images")
}

// ============================================================================
// ANALYTICS
// ============================================================================

model Analytics {
  id   String   @id @default(cuid())
  date DateTime @unique @db.Date

  // Traffic metrics
  uniqueVisitors Int @default(0) // Unique sessions
  totalPageViews Int @default(0) // Total page loads
  totalBlogViews Int @default(0) // Blog-specific views

  // Engagement metrics
  avgSessionTime Int? // Average seconds per session
  bounceRate     Float? // Percentage (0-100)

  // Conversion metrics
  contacts        Int @default(0)
  formSubmissions Int @default(0)

  // Device breakdown
  mobileVisitors  Int @default(0)
  desktopVisitors Int @default(0)
  tabletVisitors  Int @default(0)

  // Traffic sources
  directVisitors   Int @default(0)
  searchVisitors   Int @default(0)
  socialVisitors   Int @default(0)
  referralVisitors Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@map("analytics")
}

model SessionAnalytics {

  id        String @id @default(cuid())
  sessionId String @unique

  firstPagePath String // Landing page
  lastPagePath  String // Exit page
  pageCount     Int    @default(1) // Pages viewed in session
  totalDuration Int    @default(0) // Total session time (seconds)

  referrer    String? @db.Text
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  device  String? 
  browser String?
  os      String?

  ipHash  String?
  country String?
  city    String?

  converted Boolean @default(false) // Did they submit a form?
  isBounce  Boolean @default(false) // Single page visit?

  startedAt DateTime @default(now())
  endedAt   DateTime @default(now())

  @@index([sessionId])
  @@index([startedAt(sort: Desc)])
  @@index([country])
  @@index([utmSource])
  @@map("session-analytics")
}

model PageView {
  id String @id @default(cuid())

  sessionId String // Cookie-based session

  // Page information
  path      String // "/blog/my-post"
  pageTitle String? // "My Blog Post"
  pageType  String? // "blog" | "home" | "about" | "contact"

  // Traffic source
  referrer    String? @db.Text
  utmSource   String? // "google" | "facebook" | "newsletter"
  utmMedium   String? // "organic" | "cpc" | "email"
  utmCampaign String? // Campaign name

  // Device & browser
  device    String? // "mobile" | "desktop" | "tablet"
  browser   String? // "chrome" | "safari" | "firefox"
  os        String? // "windows" | "macos" | "ios" | "android"
  userAgent String? @db.Text

  // Location (from IP)
  ipHash  String? // Hashed IP for privacy
  country String? // "US" | "UK" | "EG"
  city    String? // "Cairo" | "London"

  // Engagement
  timeOnPage  Int? // Seconds spent on page
  scrollDepth Int? // Percentage scrolled (0-100)

  // Session data
  isNewSession Boolean @default(false)
  isBounce     Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([path])
  @@index([pageType])
  @@index([createdAt(sort: Desc)])
  @@index([referrer])
  @@index([utmSource])
  @@map("page_views")
}


