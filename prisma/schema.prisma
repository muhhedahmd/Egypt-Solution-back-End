// Simplified E-commerce Prisma Schema
// Removed multi-tenant domains/subdomains complexity
// Kept advanced features for single-tenant e-commerce

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN // Platform admin
}

enum Gender {
  MALE
  FEMALE
}

enum providerSession {
  GOOGLE
  CREDENTIALS
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
  id                      String   @id @default(cuid())
  name                    String
  email                   String   @unique
  password                String
  gender                  Gender   @default(MALE)
  role                    UserRole @default(ADMIN)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  is2FA                   Boolean  @default(false)
  isVerifiedForEachDevice Boolean  @default(false)
  emailConfirmed          Boolean  @default(false)
  googleId                String?
 

  profile  Profile?
  sessions Session[]

  @@map("users")
}

model Session {
  id                    String   @id @default(cuid())
  userId                String
  token                 String   @unique
  userAgent             String?
  ipAddress             String?
  refreshToken          String?
  refreshTokenExpiresAt DateTime
  isActive              Boolean  @default(true)
  deviceVerification    Boolean  @default(false)
  twoFactorVerification Boolean  @default(false)
  expiresAt             DateTime
  createdAt             DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique
  phone             String?
  dateOfBirth       DateTime?
  bio               String?
  avatarId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isProfileComplete Boolean   @default(false)

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar Image? @relation("ProfileAvatar", fields: [avatarId], references: [id])

  @@map("profiles")
}

// apparanceThemes  for later 

// ============================================================================
// CUSTOMER FEATURES
// ============================================================================

model Address {

  id         String   @id @default(cuid())
  userId     String

  CompanyInfo    String?
  address1   String
  address2   String?
  city       String
  state      String
  country    String
  postalCode String
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  AboutId String
  // Relations
  About About @relation(fields: [AboutId] , references: [id])
  @@map("addresses")
}

// ============================================================================
// MARKETING & PROMOTIONS
// ============================================================================

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================
model Services {
  id          String @unique   @default(cuid())
  description String?
  name        String
  imageId     String
  Image       Image    @relation("ServiseImage", fields: [imageId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SlideShow {
  id          String @unique   @default(cuid())
  description String?
  name        String
  imageId     String
  // Image       Image    @relation("SlideShowImage", fields: [imageId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Image       Image    @relation( "SlideShowImage",fields: [imageId], references: [id])
}

model Clients {
  id          String  @unique  @default(cuid())
  description String?
  // clientLink  String?
  name        String
  imageId     String
  Image       Image    @relation("ClientImage", fields: [imageId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model About {
  id   String  @unique @default(cuid())
  info String?
  phoneNumber  String?
  Email     String?
  Address  Address[]

}

// ============================================================================
// MEDIA MANAGEMENT
// ============================================================================

model Image {
  id        String   @id @default(cuid())
  filename  String
  url       String
  alt       String?
  size      Int? // File size in bytes
  width     Int?
  height    Int?
  blurHash  String?
  createdAt DateTime @default(now())
  //
  fileHash  String
  key       String
  typeImage String
  customId  String?

  //

  // Relations
  profileAvatars Profile[]   @relation("ProfileAvatar")
  Services       Services[]  @relation("ServiseImage")
  SlideShow      SlideShow[] @relation("SlideShowImage")
  Clients        Clients[] @relation("ClientImage")
  // Clients        Clients[]

  @@map("images")
}

// ============================================================================
// ANALYTICS
// ============================================================================

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  visitors  Int      @default(0)
  pageViews Int      @default(0)
  revenue   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@unique([date])
  @@map("analytics")
}
